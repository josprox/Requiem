#!/bin/sh

LOG_FILE=/var/log/requiem-installer.log
APP_BIN=/opt/requiem_installer/requiem_installer

{
  echo "============================================================"
  echo "Requiem Installer X session started: $(date -Iseconds)"
  echo "PATH=$PATH"
  echo "DISPLAY=$DISPLAY"
  echo "APP_BIN=$APP_BIN"
  ls -la /opt/requiem_installer || true
  ldd "$APP_BIN" || true
  echo "============================================================"
} >> "$LOG_FILE" 2>&1

# Disable screensaver and power management
xset s off
xset -dpms
xset s noblank

# Set a default cursor on the root X window (arrow cursor)
xsetroot -cursor_name left_ptr

# Start Openbox window manager in the background
openbox-session &

# Launch the Flutter installer desktop app. Do not exec it: if it exits, keep X
# alive and show a readable diagnostic instead of dropping to raw Xorg output.
"$APP_BIN" >> "$LOG_FILE" 2>&1
APP_EXIT=$?

{
  echo "============================================================"
  echo "Requiem Installer exited with code $APP_EXIT: $(date -Iseconds)"
  echo "Last log lines:"
  tail -n 200 "$LOG_FILE" || true
  echo "============================================================"
} >> "$LOG_FILE" 2>&1

if command -v xmessage >/dev/null 2>&1; then
  xmessage -center -buttons "OK:0" -file "$LOG_FILE"
fi

if command -v xterm >/dev/null 2>&1; then
  xterm -geometry 140x40 -title "Requiem Installer crash log" -e "tail -n 200 '$LOG_FILE'; echo; echo 'Press Enter to reboot or Ctrl+C to stay here.'; read _; reboot"
fi

# Fallback if neither xmessage nor xterm is available.
while true; do
  sleep 3600
done
